// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & ADMIN
// ============================================================================

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // MUST be hashed with bcrypt before storage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ============================================================================
// FORMATIONS / PROGRAMS
// ============================================================================

model Formation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String   // e.g. "Development", "Data", "Design", "Infrastructure", "Security"
  duration    String   // e.g. "6 months", "8 weeks"
  status      String   @default("Active") // "Active" | "Draft" | "Archived"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  inscriptions Inscription[]
  students     Student[]

  @@index([status])
  @@index([category])
}

// ============================================================================
// STUDENTS / ENROLLMENTS
// ============================================================================

model Student {
  id              String   @id @default(cuid())
  type            String   // "Individual" | "Company"
  
  // Individual fields (nullable for Company type)
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?
  
  // Company fields (nullable for Individual type)
  companyName     String?
  companyStudentCount Int? // number of students from this company
  
  // Common fields
  email           String   @unique
  phone           String
  status          String   @default("Active") // "Active" | "Inactive" | "Graduated"
  enrolledDate    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  formationId     String?
  formation       Formation? @relation(fields: [formationId], references: [id], onDelete: SetNull)
  inscriptions    Inscription[]
  documents       StudentDocument[]

  @@unique([type, email])
  @@index([type])
  @@index([status])
  @@index([formationId])
  @@index([email])
}

// ============================================================================
// INSCRIPTIONS / ENROLLMENT REQUESTS
// ============================================================================

model Inscription {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  formationId     String
  formation       Formation @relation(fields: [formationId], references: [id], onDelete: Restrict)
  
  type            String   // "Individual" | "Company"
  requestorName   String
  requestorEmail  String
  requestorPhone  String?
  startDate       DateTime
  numberOfStudents Int     @default(1)
  
  status          String   @default("Pending") // "Pending" | "Approved" | "Rejected"
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([studentId])
  @@index([formationId])
}

// ============================================================================
// PARTNERS
// ============================================================================

model Partner {
  id        String   @id @default(cuid())
  name      String   @unique
  website   String?
  logoUrl   String?  // Signed URL to Supabase Storage
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured])
}

// ============================================================================
// CONTACT MESSAGES
// ============================================================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("Unread") // "Unread" | "Read" | "Replied"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
}

// ============================================================================
// FILE UPLOADS & DOCUMENTS
// ============================================================================

model StudentDocument {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  fileName    String
  fileType    String   // MIME type, e.g. "application/pdf"
  fileSize    Int      // in bytes
  fileUrl     String   // Signed URL to Supabase Storage
  
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@unique([studentId, fileName])
}
